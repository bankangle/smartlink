# Copy to .env and edit before `docker compose up -d --build`.

# ---- Postgres ----
POSTGRES_DB=smartlink
POSTGRES_USER=smartlink
POSTGRES_PASSWORD=change-this-password

# ---- Admin login (seeded on first boot) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-too

# ---- Auth ----
# Any long random string. e.g. `openssl rand -base64 48`
JWT_KEY=replace-with-a-long-random-secret-string

# ---- Public origin & TLS ----
# Production: your domain. Caddy will auto-provision HTTPS for it.
#   SITE_ADDRESS=links.example.com
#   PUBLIC_ORIGIN=https://links.example.com
# Local testing over plain HTTP:
SITE_ADDRESS=:80
PUBLIC_ORIGIN=http://localhost
HTTP_PORT=80
HTTPS_PORT=443

# ---- Deezer pre-save (optional) ----
# Register a free app at https://developers.deezer.com/myapps
# Redirect URL must be <PUBLIC_ORIGIN>/api/deezer/callback
DEEZER_APP_ID=
DEEZER_SECRET_KEY=

# ---- Spotify pre-save (optional) ----
# Register a free app at https://developer.spotify.com/dashboard
# Redirect URI must be <PUBLIC_ORIGIN>/api/spotify/callback
# In development mode add each tester's Spotify email under "User Management"
# (up to 25). Leave blank to run the pre-save in clickable demo mode.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ---- Demo ----
# Seed a demo page on first boot (needs outbound internet for Odesli).
SEED_DEMO=true
